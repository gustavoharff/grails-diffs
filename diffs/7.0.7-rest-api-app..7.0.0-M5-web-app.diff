diff --git a/myapp/src/integration-test/groovy/myapp/MyappSpec.groovy b/myapp/src/integration-test/groovy/myapp/MyappSpec.groovy
new file mode 100644
index 00000000..0ac133d7
--- /dev/null
+++ b/myapp/src/integration-test/groovy/myapp/MyappSpec.groovy
@@ -0,0 +1,19 @@
+package myapp
+import grails.plugin.geb.ContainerGebSpec
+import grails.testing.mixin.integration.Integration
+
+/**
+ * See https://docs.grails.org/latest/guide/testing.html#functionalTesting and https://www.gebish.org/manual/current/
+ * for more instructions on how to write functional tests with Grails and Geb.
+ */
+@Integration
+class MyappSpec extends ContainerGebSpec {
+
+    void 'should display the correct title on the home page'() {
+        when: 'visiting the home page'
+            go('/')
+
+        then: 'the page title is correct'
+            title == 'Welcome to Grails'
+    }
+}
